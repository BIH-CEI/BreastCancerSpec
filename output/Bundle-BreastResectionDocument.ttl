  fhir:section ( [
     fhir:title [ fhir:v "Pathologiebefundbericht" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:11526-1 ;
         fhir:system [
           fhir:v "http://loinc.org"^^xsd:anyURI ;
           fhir:l <http://loinc.org>
         ] ;
